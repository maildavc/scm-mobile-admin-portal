{
  "info": {
    "name": "Customer Management Integration Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var jsonData = pm.response.json();",
              "console.log('Login Response:', jsonData);",
              "if(jsonData && jsonData.data && jsonData.data.accessToken) {",
              "  pm.environment.set('accessToken', jsonData.data.accessToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"admin@scmcapital.com\", \"password\": \"P@ssw0rd!\", \"token\": \"1234\"}"
        },
        "url": {
          "raw": "http://10.114.0.3:5000/api/v1/auth/login",
          "protocol": "http",
          "host": ["10", "114", "0", "3"],
          "port": "5000",
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "Get Customers",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "console.log('Get Customers Response:', pm.response.json());"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": {
          "raw": "http://10.114.0.3:5000/api/v1/customers?page=1&limit=10",
          "protocol": "http",
          "host": ["10", "114", "0", "3"],
          "port": "5000",
          "path": ["api", "v1", "customers"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    }
  ]
}
